                                    </span>
                                </li>

                                <!-- Puce 2 -->
                                <li class="flex items-start gap-3 modal-bullet">
                                    <svg class="w-4 h-4 lg:w-5 lg:h-5 text-success-green flex-shrink-0 mt-0.5"
