---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
// Layout global du site : contient tout le head et la structure du body.
// La page injecte son contenu via la balise slot.
// Les scripts tiers (Google Analytics, ScrollReveal, Brevo) sont marques is:inline
// pour qu'Astro les laisse intacts, comme sur le site actuel.

// Props paramétrables par page. Les valeurs par défaut = celles de la page d'accueil,
// pour que index.astro continue de fonctionner sans rien passer.
const {
  title = "Création de Site Web pour Coach & Thérapeute | Agence Clartem",
  description = "Agence spécialisée dans la création de sites web pour coachs, thérapeutes et professionnels du bien-être. Attirez plus de clients avec un site clair, professionnel et qui inspire confiance.",
  bodyClass = "bg-white",
  leadMagnet = false,  // cadeau/lead magnet : activable par page
  noindex = false,     // pages légales/merci : non indexées par les moteurs
} = Astro.props;

// L'URL canonique de la page courante, calculée automatiquement.
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>

    <!-- FAVICON -->
    <link rel="icon" type="image/x-icon" href="/assets/favicon-clartem.ico">

    <meta name="description" content={description}>
    {noindex && <meta name="robots" content="noindex, follow" />}
    <meta name="author" content="clartem.com">



    <!-- ======================================================= -->
    <!--       DÉBUT DU BLOC SEO & ANALYTICS (A NE PAS TOUCHER)  -->
    <!-- ======================================================= -->

    <!-- 1. Google Analytics (GA4) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-54GH7QYLQP"></script>
    <script is:inline>
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag('js', new Date());

        gtag('config', 'G-54GH7QYLQP');
    </script>

    <!-- 2. Balise Canonique (L'originale) -->
    <link rel="canonical" href={canonical} />

    <!-- 3. Ciblage Géographique (France) -->
    <link rel="alternate" hreflang="fr-fr" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />

    <!-- 4. Données Structurées : ORGANISATION (Uniquement sur l'accueil) -->
    <script is:inline type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Agence Clartem",
      "url": "https://www.clartem.com/",
      "logo": "https://www.clartem.com/assets/logo-clartem.svg",
      "description": "Agence web spécialisée pour les coachs et thérapeutes.",
      "address": {
        "@type": "PostalAddress",
        "addressCountry": "FR"
      }
    }
    </script>

    <!-- ======================================================= -->
    <!--       FIN DU BLOC SEO                                   -->
    <!-- ======================================================= -->



    <!-- Meta Tags Open Graph & Twitter -->
    <meta property="og:type" content="website">
    <meta property="og:url" content={canonical}>
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>

    <!-- Configuration de l'image -->
    <meta property="og:image" content="https://www.clartem.com/assets/og-clartem.jpeg">
    <meta property="og:image:type" content="image/jpeg">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Création de Site Web pour Coach & Thérapeute | Agence Clartem">
    <meta name="twitter:description"
        content="Agence spécialisée pour les coachs et thérapeutes. Un site clair et professionnel qui vous ressemble.">
    <meta name="twitter:image" content="https://www.clartem.com/assets/og-clartem.jpeg">

    <!-- ScrollReveal.js via CDN (NOUVEAU) -->
    <script is:inline src="https://unpkg.com/scrollreveal"></script>
    

    <!-- Custom CSS -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Source+Code+Pro:ital,wght@0,300;0,400;0,600;1,300;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">

    <!-- Critical : Masquer le launcher Brevo -->
    <style>
        /* État fermé : réduit à zéro, instantané, GPU-acceleré */
        #brevo-conversations.clartem-hidden {
            transform: scale(0) !important;
            pointer-events: none !important;
        }
        /* État transitoire pendant l'ouverture : présent mais invisible */
        #brevo-conversations.clartem-opening {
            opacity: 0 !important;
            pointer-events: none !important;
        }
    </style>

    <!-- Emplacement pour les balises <head> propres à une page (ex. JSON-LD spécifique). -->
    <slot name="head" />
</head>

<body class={bodyClass}>
    <!-- Conteneur principal : Navbar + contenu de page (slot) + Footer -->
    <div class="min-h-screen">
        <Navbar />

        <slot />

        <Footer />
    </div>

    <!-- ===== Éléments globaux (présents sur toutes les pages) ===== -->

    <!-- BANDEAU DE CONSENTEMENT AUX COOKIES (VERSION RESPONSIVE AMÉLIORÉE) -->
    <div id="cookie-consent-banner" class="hidden fixed bottom-0 inset-x-0 p-2 sm:p-4 z-[100]">
        <div class="max-w-7xl mx-auto">
            <div
                class="p-4 rounded-lg bg-neutral-dark shadow-lg flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">

                <!-- Section Texte -->
                <div class="flex-1 text-white">
                    <p class="font-semibold">Ce site utilise des cookies</p>
                    <p class="mt-1 text-sm text-neutral-light">
                        Nous utilisons des cookies pour améliorer votre expérience et analyser notre trafic. En
                        cliquant
                        sur "Accepter", vous consentez à notre utilisation des cookies.
                        <a href="/politique-de-confidentialite/" target="_blank"
                            class="font-semibold hover:underline">En savoir plus</a>.
                    </p>
                </div>

                <!-- Section Boutons -->
                <div class="flex flex-col sm:flex-row gap-3 w-full sm:w-auto">
                    <button id="cookie-accept-btn" type="button" class="w-full sm:w-auto btn btn-primary px-6 py-2">
                        Accepter
                    </button>
                    <button id="cookie-decline-btn" type="button" class="w-full sm:w-auto btn btn-secondary px-6 py-2"
                        style="color: white; border-color: white;">
                        Refuser
                    </button>
                </div>

            </div>
        </div>
    </div>
    <!-- FIN DU BANDEAU DE CONSENTEMENT -->

    <!-- Lead magnet (cadeau) — affiché seulement si la page le demande -->
