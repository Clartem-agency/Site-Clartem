            </svg>
        </span>
        <span class="clartem-chat-btn__badge"></span>
    </button>

    <!-- Script Brevo + connexion au bouton custom -->
    <script is:inline>
        (function (d, w, c) {
            w.BrevoConversationsID = '688afd5eb78a71119e0a4e37';
            w[c] = w[c] || function () {
                (w[c].q = w[c].q || []).push(arguments);
            };

            var s = d.createElement('script');
            s.async = true;
            s.src = 'https://conversations-widget.brevo.com/brevo-conversations.js';
            if (d.head) d.head.appendChild(s);

            // --------------------------------------------------
            // Stratégie simple :
            // Le launcher Brevo est dans une iframe INSIDE #brevo-conversations
            // Ce div fait 60x60 quand fermé → on le cache avec une classe
            // Quand on ouvre le chat → on retire la classe → Brevo affiche le chat
            // Quand on ferme → on remet la classe
            // --------------------------------------------------

            // Ajouter la classe "clartem-hidden" dès que #brevo-conversations apparaît
            // (mais pas si on est en train d'ouvrir ou si le chat est affiché)
            function hideBrevoContainer() {
                var el = d.getElementById('brevo-conversations');
                var chatBtn = d.getElementById('clartemChatBtn');
                if (el && !el.classList.contains('clartem-hidden')
                       && !el.classList.contains('clartem-opening')
                       && !(chatBtn && chatBtn.classList.contains('is-open'))) {
                    el.classList.add('clartem-hidden');
                }
            }

            // Observer le DOM pour cacher le conteneur dès son injection
            var observer = new MutationObserver(hideBrevoContainer);
            function startObserving() {
                observer.observe(d.body || d.documentElement, {
                    childList: true,
                    subtree: true
                });
            }
            if (d.body) startObserving();
            else d.addEventListener('DOMContentLoaded', startObserving);

            // Fallback les premières secondes
            var checks = 0;
            var interval = setInterval(function() {
                hideBrevoContainer();
                var el = d.getElementById('brevo-conversations');
                if ((el && el.classList.contains('clartem-hidden')) || ++checks > 50) {
                    clearInterval(interval);
                }
            }, 200);

            // --------------------------------------------------
            // Connexion du bouton custom au chat Brevo
            // 3 états :
            //   clartem-hidden  = scale(0), invisible, pas de clics
            //   clartem-opening = opacity(0), l'élément EXISTE pour que Brevo puisse ouvrir
            //   (aucune classe) = visible, le chat est affiché
            // --------------------------------------------------
            var btn = d.getElementById('clartemChatBtn');
            var openPollTimer = null;

            btn.addEventListener('click', function() {
                var brevoEl = d.getElementById('brevo-conversations');
                if (!brevoEl) return;

                var isHidden = brevoEl.classList.contains('clartem-hidden')
                            || brevoEl.classList.contains('clartem-opening');

                if (isHidden || !btn.classList.contains('is-open')) {
                    // === OUVRIR LE CHAT ===

                    // Étape 1 : passer de "hidden" à "opening"
                    // Le conteneur existe dans le DOM (pas scale 0)
                    // mais il est invisible (opacity 0)
                    brevoEl.classList.remove('clartem-hidden');
                    brevoEl.classList.add('clartem-opening');

                    // Étape 2 : demander à Brevo d'ouvrir
                    try { w.BrevoConversations('openChat', true); } catch(e) {}

                    // Étape 3 : poll jusqu'à ce que le chat soit ouvert
                    var attempts = 0;
                    var retried = false;
                    clearInterval(openPollTimer);
                    openPollTimer = setInterval(function() {
                        attempts++;

                        // Réessayer une fois après 1.5s si pas encore ouvert
                        if (attempts === 30 && !retried) {
                            retried = true;
                            try { w.BrevoConversations('openChat', true); } catch(e) {}
                        }

                        if (brevoEl.offsetHeight > 150) {
                            // ✅ Chat ouvert → rendre visible
                            brevoEl.classList.remove('clartem-opening');
                            btn.classList.add('is-open');
                            clearInterval(openPollTimer);
                        } else if (attempts > 80) {
                            // ❌ Échec → re-cacher
                            brevoEl.classList.remove('clartem-opening');
                            brevoEl.classList.add('clartem-hidden');
                            btn.classList.remove('is-open');
                            clearInterval(openPollTimer);
                        }
                    }, 50);

                } else {
                    // === FERMER LE CHAT ===
                    // Style inline = synchrone, garanti avant le prochain paint
                    clearInterval(openPollTimer);
                    brevoEl.style.setProperty('opacity', '0', 'important');
                    brevoEl.style.setProperty('pointer-events', 'none', 'important');
                    btn.classList.remove('is-open');
                    // Au frame suivant : passer en scale(0) et nettoyer le style inline
                    requestAnimationFrame(function() {
                        brevoEl.classList.remove('clartem-opening');
                        brevoEl.classList.add('clartem-hidden');
                        brevoEl.style.removeProperty('opacity');
                        brevoEl.style.removeProperty('pointer-events');
                    });
                }
            });

            // Sync : si l'utilisateur ferme le chat depuis le widget Brevo
            setInterval(function() {
                var brevoEl = d.getElementById('brevo-conversations');
                if (!brevoEl) return;
                if (!btn.classList.contains('is-open')) return;
                try {
                    if (brevoEl.offsetWidth <= 80 && brevoEl.offsetHeight <= 80) {
                        brevoEl.style.setProperty('opacity', '0', 'important');
                        brevoEl.style.setProperty('pointer-events', 'none', 'important');
                        btn.classList.remove('is-open');
                        requestAnimationFrame(function() {
                            brevoEl.classList.remove('clartem-opening');
                            brevoEl.classList.add('clartem-hidden');
                            brevoEl.style.removeProperty('opacity');
                            brevoEl.style.removeProperty('pointer-events');
                        });
                    }
                } catch(e) {}
            }, 500);

            // --------------------------------------------------
            // BULLE PROACTIVE
            // --------------------------------------------------
            var PROACTIVE_MESSAGES = {
                first:  'Besoin d\u2019un coup de main pour votre projet de site\u00a0?',
                second: 'Toujours l\u00e0 si besoin\u00a0!'
            };
            var PROACTIVE_TYPING_MS     = 1200;
            var PROACTIVE_AUTO_DISMISS  = 15000;
            var PROACTIVE_STORAGE_KEY   = 'clartem_proactive_dismissed';
            var PROACTIVE_SCROLL_2ND    = 0.70;

            var proBubble    = d.getElementById('clartemProactive');
            var proMessage   = d.getElementById('proactiveMessage');
            var proActions   = d.getElementById('proactiveActions');
            var proBtnYes    = d.getElementById('proactiveYes');
            var proBtnNo     = d.getElementById('proactiveNo');
            var proBtnClose  = d.getElementById('proactiveClose');

            var proDismissCount  = parseInt(sessionStorage.getItem(PROACTIVE_STORAGE_KEY) || '0', 10);
            var proIsShowing     = false;
            var proAutoTimer     = null;
            var proFirstDone     = false;
            var proSecondDone    = false;

            var proTypingHTML = '<div class="clartem-proactive__typing">'
                + '<span class="clartem-proactive__typing-dot"></span>'
                + '<span class="clartem-proactive__typing-dot"></span>'
                + '<span class="clartem-proactive__typing-dot"></span></div>';

            function proShow(variant) {
                if (proIsShowing || proDismissCount >= 2) return;
                if (btn.classList.contains('is-open')) return;

                proIsShowing = true;
                proMessage.innerHTML = proTypingHTML;
                proActions.style.display = 'none';
                proBubble.classList.remove('is-hiding');
                proBubble.classList.add('is-typing');

                requestAnimationFrame(function() {
                    proBubble.classList.add('is-visible');
                });

                setTimeout(function() {
                    proMessage.textContent = PROACTIVE_MESSAGES[variant];
                    proBubble.classList.remove('is-typing');
                    proActions.style.display = 'flex';

                    if (variant === 'second') {
                        proBtnYes.textContent = 'Discutons\u00a0!';
                        proBtnNo.textContent = '\u00c7a ira';
                    } else {
                        proBtnYes.textContent = 'Oui, avec plaisir\u00a0!';
                        proBtnNo.textContent = 'Non merci';
                    }
                }, PROACTIVE_TYPING_MS);

                clearTimeout(proAutoTimer);
                proAutoTimer = setTimeout(function() {
                    proHide(false);
                }, PROACTIVE_AUTO_DISMISS + PROACTIVE_TYPING_MS);
            }

            function proHide(countAsDismiss) {
                if (!proIsShowing) return;
                proIsShowing = false;
                clearTimeout(proAutoTimer);
                proBubble.classList.add('is-hiding');
                proBubble.classList.remove('is-visible');
                if (countAsDismiss) {
                    proDismissCount++;
                    sessionStorage.setItem(PROACTIVE_STORAGE_KEY, String(proDismissCount));
                }
                setTimeout(function() {
                    proBubble.classList.remove('is-hiding', 'is-typing');
                }, 300);
            }

            // Clic "Oui" → ouvre le chat
            proBtnYes.addEventListener('click', function() {
                proHide(false);
                btn.click();
            });

            proBtnNo.addEventListener('click', function() { proHide(true); });
            proBtnClose.addEventListener('click', function() { proHide(true); });

            // TRIGGER 1 : IntersectionObserver sur #site-concept
            var proTarget = d.getElementById('site-concept');
            if (proTarget) {
                var proObserver = new IntersectionObserver(function(entries) {
                    entries.forEach(function(entry) {
                        if (entry.isIntersecting && !proFirstDone && proDismissCount < 2) {
                            proFirstDone = true;
                            proObserver.disconnect();
                            setTimeout(function() { proShow('first'); }, 800);
                        }
                    });
                }, { threshold: 0.15 });
                proObserver.observe(proTarget);
            }

            // TRIGGER 2 : 70% du scroll
            w.addEventListener('scroll', function proScrollCheck() {
                if (proSecondDone) return;
                var scrollTotal = d.documentElement.scrollHeight - w.innerHeight;
                var scrollCurrent = w.scrollY;
                if (scrollTotal > 0 && (scrollCurrent / scrollTotal) > PROACTIVE_SCROLL_2ND) {
                    proSecondDone = true;
                    w.removeEventListener('scroll', proScrollCheck);
                    if (proFirstDone && !proIsShowing && proDismissCount < 2
                        && !btn.classList.contains('is-open')) {
                        setTimeout(function() { proShow('second'); }, 600);
                    }
                }
            }, { passive: true });

            // SYNC : cacher la bulle si le chat s'ouvre
            var proSyncObserver = new MutationObserver(function() {
                if (btn.classList.contains('is-open') && proIsShowing) {
                    proHide(false);
                }
            });
            proSyncObserver.observe(btn, { attributes: true, attributeFilter: ['class'] });

        })(document, window, 'BrevoConversations');
    </script>
    <!-- Fin Chat Brevo + Bouton Custom -->
</body>

</html>
