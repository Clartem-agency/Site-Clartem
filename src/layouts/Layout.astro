    <!-- Bouton custom Clartem (remplace le launcher Brevo) -->
    <button class="clartem-chat-btn" id="clartemChatBtn" aria-label="Ouvrir le chat">
        <span class="clartem-chat-btn__glow"></span>
        <span class="clartem-chat-btn__disc">
            <svg class="clartem-chat-btn__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
                <circle cx="9.5" cy="12" r="0.8" fill="currentColor" stroke="none" class="clartem-dot clartem-dot--1"/>
                <circle cx="12" cy="12" r="0.8" fill="currentColor" stroke="none" class="clartem-dot clartem-dot--2"/>
                <circle cx="14.5" cy="12" r="0.8" fill="currentColor" stroke="none" class="clartem-dot clartem-dot--3"/>
            </svg>
