    <!-- ======================================================= -->
    <!-- TEASER LEAD MAGNET (CADEAU PREMIUM 2.0)                 -->
    <!-- ======================================================= -->
    <div id="lead-magnet-teaser"
        class="fixed bottom-4 left-4 z-[90] hidden cursor-pointer group w-[72px] h-[72px] flex items-end justify-center perspective-500 transition-transform duration-500 ease-out">

        <!-- L'ILLUSTRATION SVG PREMIUM 3D -->
        <svg width="72" height="80" viewBox="0 0 100 110" fill="none" xmlns="http://www.w3.org/2000/svg"
            class="overflow-visible filter drop-shadow-[0_8px_20px_rgba(249,115,22,0.3)]">

            <!-- Groupe global pour l'animation de saut -->
            <g class="gift-anim-container origin-bottom">

                <!-- OMBRE AU SOL multi-couche realiste -->
                <ellipse cx="50" cy="102" rx="32" ry="5" fill="black" fill-opacity="0.15"
                    class="gift-shadow-anim origin-center" />
                <ellipse cx="50" cy="102" rx="22" ry="3.5" fill="black" fill-opacity="0.2"
                    class="gift-shadow-anim origin-center" />

                <!-- ===================== -->
                <!-- BOITE (CORPS 3D)      -->
                <!-- ===================== -->

                <!-- Face avant principale -->
                <rect x="20" y="48" width="60" height="47" rx="3" fill="url(#boxFrontGrad)" />

                <!-- Face droite (perspective 3D) -->
                <path d="M80 48 L86 43 L86 90 L80 95" fill="url(#boxSideGrad)" />

                <!-- Face du dessous (perspective 3D subtile) -->
                <path d="M20 95 L80 95 L86 90 L26 90" fill="#7C2D12" opacity="0.6" />

                <!-- Reflet speculaire haut-gauche (eclat de lumiere) -->
                <rect x="22" y="49" width="28" height="18" rx="2" fill="url(#specularHighlight)" />

                <!-- Ombre interne sous le couvercle (ambient occlusion) -->
                <rect x="20" y="48" width="60" height="8" rx="3" fill="url(#aoShadow)" />

                <!-- Ruban Vertical (Corps) — Effet Satin dore -->
                <rect x="45" y="48" width="10" height="47" fill="url(#ribbonSatin)" />
                <!-- Ruban cote droit -->
                <path d="M55 48 L58 45 L58 92 L55 95" fill="url(#ribbonSatinSide)" />

                <!-- Arete lumineuse bord gauche -->
                <line x1="20" y1="48" x2="20" y2="95" stroke="white" stroke-opacity="0.15" stroke-width="1" />

                <!-- LUEUR MAGIQUE (Derriere le couvercle, apparait au saut) -->
                <g class="gift-glow-anim">
                    <ellipse cx="50" cy="46" rx="30" ry="6" fill="#FDE047" filter="url(#glowFilter)" opacity="0.9" />
                    <ellipse cx="50" cy="46" rx="15" ry="3" fill="white" filter="url(#glowFilter)" opacity="0.4" />
                </g>

                <!-- ===================== -->
                <!-- LE COUVERCLE 3D       -->
                <!-- ===================== -->
                <g class="gift-lid-anim origin-bottom">
                    <!-- Face avant couvercle -->
                    <rect x="16" y="36" width="68" height="14" rx="2.5" fill="url(#lidFrontGrad)" />

                    <!-- Face dessus couvercle -->
                    <path d="M16 36 L22 31 L90 31 L84 36" fill="url(#lidTopGrad)" />

                    <!-- Face droite couvercle -->
                    <path d="M84 36 L90 31 L90 45 L84 50" fill="url(#lidSideGrad)" />

                    <!-- Reflet speculaire couvercle -->
                    <rect x="18" y="37" width="30" height="5" rx="1.5" fill="white" fill-opacity="0.15" />

                    <!-- Arete lumineuse couvercle -->
                    <line x1="16" y1="36" x2="22" y2="31" stroke="white" stroke-opacity="0.25" stroke-width="0.8" />
                    <line x1="22" y1="31" x2="90" y2="31" stroke="white" stroke-opacity="0.12" stroke-width="0.8" />

                    <!-- Ruban Horizontal (Couvercle) -->
                    <rect x="45" y="36" width="10" height="14" fill="url(#ribbonSatin)" />
                    <!-- Ruban dessus couvercle -->
                    <path d="M45 36 L48 31 L58 31 L55 36" fill="url(#ribbonSatinTop)" />
                    <!-- Ruban cote droit couvercle -->
                    <path d="M55 36 L58 31 L58 45 L55 50" fill="url(#ribbonSatinSide)" />

                    <!-- LE NOEUD PREMIUM -->
                    <g transform="translate(51, 32)">
                        <!-- Ombre du noeud -->
                        <ellipse cx="0" cy="5" rx="14" ry="3" fill="black" fill-opacity="0.15" />

                        <!-- Boucle Gauche avec volume -->
