---
// Barre de navigation + menu mobile. Composant global (réutilisable sur toutes les pages).
---
        <nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-transparent">
            <!-- MODIFIÉ : J'ai retiré la classe 'py-4' ici pour que le CSS contrôle totalement la hauteur -->
            <div class="container mx-auto px-6">
                <div class="flex items-center justify-between">

                    <!-- LOGO : Taille réduite de h-14 à h-10 (40px) pour affiner la barre -->
                    <a href="/" class="relative block group py-2"> <!-- Ajout d'un petit py-2 de sécurité -->
                        <img id="logo-white" class="h-10 w-auto transition-opacity duration-300"
                            src="/assets/logo-blanc-clartem.svg" alt="Logo clartem.com blanc">

                        <img id="logo-color"
                            class="h-10 w-auto absolute top-2 left-0 transition-opacity duration-300 opacity-0"
                            src="/assets/logo-clartem.svg" alt="Logo clartem.com couleur">
                    </a>

                    <!-- LIENS DU MENU -->
                    <div class="hidden lg:flex items-center space-x-8" id="nav-links">
                        <!-- J'ai ajouté text-sm pour que le texte soit un peu plus fin et élégant -->
                        <a href="/a-propos/" class="nav-link text-sm font-medium transition-colors duration-300">À
                            Propos</a>
                        <a href="/creation-site-web-therapeute/"
                            class="nav-link text-sm font-medium transition-colors duration-300">Création de
                            site</a>
                        <a href="/#plan"
                            class="nav-link text-sm font-medium transition-colors duration-300">Processus</a>
                        <a href="/portfolio/"
                            class="nav-link text-sm font-medium transition-colors duration-300">Portfolio</a>
                        <a href="/#offres"
                            class="nav-link text-sm font-medium transition-colors duration-300">Offres</a>
                        <a href="/blog/" class="nav-link text-sm font-medium transition-colors duration-300">Blog</a>
                        <a href="/faq/" class="nav-link text-sm font-medium transition-colors duration-300">FAQ</a>
                    </div>

                    <!-- BOUTON D'APPEL : Taille réduite de h-12 à h-10 et texte un peu plus petit -->
                    <a href="https://calendly.com/clartem-agency/appel-clarte-creation-de-site-web" target="_blank"
                        rel="noopener noreferrer"
                        class="hidden md:inline-flex items-center justify-center btn btn-primary px-6 h-10 text-sm">Planifier
                        un Appel Clarté
                    </a>

                    <!-- BOUTON MENU MOBILE -->
                    <button id="mobile-menu-button"
                        class="lg:hidden relative z-[60] w-10 h-10 flex items-center justify-center focus:outline-none group">
                        <div class="relative w-6 h-5 flex flex-col justify-between">
                            <!-- Ligne du haut -->
                            <span id="burger-top"
                                class="block w-full h-0.5 bg-current rounded-full transition-all duration-300 origin-center"></span>
                            <!-- Ligne du milieu -->
                            <span id="burger-middle"
                                class="block w-full h-0.5 bg-current rounded-full transition-all duration-300 opacity-100"></span>
                            <!-- Ligne du bas -->
                            <span id="burger-bottom"
                                class="block w-full h-0.5 bg-current rounded-full transition-all duration-300 origin-center"></span>
                        </div>
                    </button>
                </div>


            </div>
        </nav>


        <!-- ======================================================= -->
        <!--                        MENU MOBILE                      -->
        <!-- ======================================================= -->
        <div id="mobile-menu-overlay"
            class="fixed inset-0 z-[49] bg-neutral-dark/95 backdrop-blur-xl opacity-0 pointer-events-none transition-opacity duration-500 flex flex-col justify-center items-center">

            <!-- Décoration de fond (Optionnel : Orbe subtile) -->
            <div
                class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-clarity-blue/10 rounded-full blur-[100px] pointer-events-none">
            </div>

            <!-- Liste des liens -->
            <div class="relative z-10 flex flex-col items-center space-y-8 text-center">

                <a href="/a-propos/"
                    class="mobile-link text-3xl font-bold text-white hover:text-warm-orange transition-colors duration-300 transform translate-y-4 opacity-0">À
                    Propos</a>

                <a href="/creation-site-web-therapeute/"
                    class="mobile-link text-3xl font-bold text-white hover:text-warm-orange transition-colors duration-300 transform translate-y-4 opacity-0">Création
                    de site</a>

                <a href="/#plan"
                    class="mobile-link text-3xl font-bold text-white hover:text-warm-orange transition-colors duration-300 transform translate-y-4 opacity-0"
                    style="transition-delay: 0.1s;">Processus</a>

                <a href="/portfolio/"
                    class="mobile-link text-3xl font-bold text-white hover:text-warm-orange transition-colors duration-300 transform translate-y-4 opacity-0"
                    style="transition-delay: 0.2s;">Portfolio</a>

                <a href="/#offres"
                    class="mobile-link text-3xl font-bold text-white hover:text-warm-orange transition-colors duration-300 transform translate-y-4 opacity-0"
                    style="transition-delay: 0.3s;">Offres</a>

                <a href="/blog/"
                    class="mobile-link text-3xl font-bold text-white hover:text-warm-orange transition-colors duration-300 transform translate-y-4 opacity-0"
                    style="transition-delay: 0.4s;">Blog</a>

                <a href="/faq/"
                    class="mobile-link text-3xl font-bold text-white hover:text-warm-orange transition-colors duration-300 transform translate-y-4 opacity-0"
                    style="transition-delay: 0.5s;">FAQ</a>

                <!-- Le Bouton d'action (plus petit que les titres) -->
                <div class="pt-8 mobile-link transform translate-y-4 opacity-0" style="transition-delay: 0.6s;">
                    <a href="https://calendly.com/clartem-agency/appel-clarte-creation-de-site-web" target="_blank"
                        class="btn btn-primary px-8 py-3 text-lg rounded-full">
                        Planifier un Appel
                    </a>
                </div>
            </div>

            <!-- Footer du menu (Email / Copyright) -->
            <div class="absolute bottom-8 text-white/30 text-xs tracking-widest uppercase">
                Clartem Agency © 2025
            </div>
        </div>
