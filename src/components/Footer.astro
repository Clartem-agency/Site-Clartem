---
// Pied de page du site. Composant global (réutilisable sur toutes les pages).
---
        <footer class="bg-neutral-dark border-t border-white/10 text-white py-16 relative overflow-hidden">



            <div class="container mx-auto px-6 relative z-10">
                <div class="grid md:grid-cols-3 gap-12">
                    <!-- (Contenu du footer inchangé...) -->
                    <div class="space-y-6">
                        <div>
                            <a href="/">
                                <img class="h-14 w-auto" src="/assets/logo-blanc-clartem.svg" alt="Logo clartem.com">
                            </a>
                            <p class="text-lg text-neutral-light">Apporter de la clarté dans le chaos digital</p>
                        </div>
                        <p class="text-neutral-light leading-relaxed">Vous transformez des vies, votre site devrait
                            le
                            refléter. J'aide les professionnels de l'accompagnement à traduire leur expertise en une
                            présence digitale claire.</p>
                    </div>
                    <div class="space-y-6">
                        <h4 class="text-xl font-bold text-white">Navigation</h4>
                        <div class="space-y-3">
                            <a href="/a-propos/"
                                class="block text-neutral-light hover:text-clarity-blue transition-colors duration-300">À
                                Propos</a>
                            <a href="/#plan"
                                class="block text-neutral-light hover:text-clarity-blue transition-colors duration-300">Processus</a>
                            <a href="/portfolio/"
                                class="block text-neutral-light hover:text-clarity-blue transition-colors duration-300">Portfolio</a>
                            <a href="/#offres"
                                class="block text-neutral-light hover:text-clarity-blue transition-colors duration-300">Offres</a>
                            <a href="/blog/"
                                class="block text-neutral-light hover:text-clarity-blue transition-colors duration-300">Blog</a>
                            <a href="/faq/"
                                class="block text-neutral-light hover:text-clarity-blue transition-colors duration-300">FAQ</a>
                        </div>
                    </div>
                    <div class="space-y-6">
                        <h4 class="text-xl font-bold text-white">Informations Légales</h4>
                        <div class="space-y-3">
                            <a href="/mentions-legales/"
                                class="block text-neutral-light hover:text-clarity-blue transition-colors duration-300">Mentions
                                Légales</a>
                            <a href="/politique-de-confidentialite/"
                                class="block text-neutral-light hover:text-clarity-blue transition-colors duration-300">Politique
                                de Confidentialité</a>
                            <a href="/cgv/"
                                class="block text-neutral-light hover:text-clarity-blue transition-colors duration-300">Conditions
                                Générales de Vente</a>
                            <a href="/contact/"
                                class="block text-neutral-light hover:text-clarity-blue transition-colors duration-300">Contact</a>
                            <!-- AJOUTER CETTE LIGNE ICI : -->
                            <a href="#" id="open-cookie-settings"
                                class="block text-neutral-light hover:text-clarity-blue transition-colors duration-300">Gestion
                                des cookies</a>
                        </div>
                    </div>
                </div>
                <!-- Ligne de séparation interne du footer conservée, mais adoucie -->
                <div class="border-t border-white/5 mt-12 pt-8">
                    <div class="flex flex-col md:flex-row justify-between items-center gap-4">
                        <p class="text-sm text-neutral-light">© 2025 clartem.com. Tous droits réservés.</p>
                        <div class="text-sm text-neutral-light">
                            <span>Conçu avec ❤️ pour apporter de la clarté dans le chaos digital</span>
                        </div>
                    </div>
                </div>
            </div>
        </footer>
