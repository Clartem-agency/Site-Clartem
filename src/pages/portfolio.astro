---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Portfolio Clartem - Exemples de sites pour Coachs & Thérapeutes"
  description="Découvrez nos réalisations de sites web pour coachs et thérapeutes. Des exemples concrets de Sites Clarté conçus pour inspirer confiance et convertir."
  bodyClass="bg-neutral-dark dark-nav-page"
>

<style is:global>
        /* Styles spécifiques pour la page portfolio */
        .portfolio-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            transition: all 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            /* Carte rendue sur une couche GPU : évite que la bordure du bas
               scintille au sous-pixel pendant le micro-zoom au survol. */
            -webkit-backface-visibility: hidden;
            backface-visibility: hidden;
            will-change: transform;
        }

        .portfolio-card:hover {
            background: rgba(255, 255, 255, 0.06);
            border-color: rgba(59, 130, 246, 0.4);
            /* Soulèvement seul (translateY, pixels entiers). Les deux micro-zooms au
               survol (carte + image) ont été retirés : c'étaient eux qui posaient le bord
               bas de l'image sur un sous-pixel et créaient le liseré blanc clignotant.
               Imperceptibles à l'œil → aucun changement visible, bug réglé. */
            transform: translateY(-8px) translateZ(0);
            box-shadow:
                0 25px 50px -12px rgba(0, 0, 0, 0.5),
                0 0 30px rgba(59, 130, 246, 0.15);
        }

        .portfolio-card .card-image {
            position: relative;
            overflow: hidden;
            /* Couche GPU + clipping net : supprime le liseré blanc sous-pixel
               quand l'image passe en scale au survol. */
            transform: translateZ(0);
            -webkit-backface-visibility: hidden;
            backface-visibility: hidden;
        }

        .portfolio-card .card-image::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(31, 41, 55, 0.9) 0%, transparent 50%);
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .portfolio-card:hover .card-image::after {
            opacity: 1;
        }

        .portfolio-card .card-image img {
            -webkit-backface-visibility: hidden;
            backface-visibility: hidden;
        }

        /* Zoom de l'image au survol RETIRÉ : c'était la cause restante du liseré
           (image agrandie rognée par overflow:hidden → bord bas sur un sous-pixel).
           Le survol reste vivant via le soulèvement de la carte + le voile ::after. */

        /* Filter buttons */
        .filter-btn-dark {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: rgba(255, 255, 255, 0.7);
            transition: all 0.3s ease;
        }

        .filter-btn-dark:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: rgba(255, 255, 255, 0.2);
            color: white;
        }

        .filter-btn-dark.active {
            background: linear-gradient(135deg, #3B82F6, #1E3A8A);
            border-color: transparent;
            color: white;
            box-shadow: 0 4px 15px rgba(59, 130, 246, 0.3);
        }

        /* Tags */
        .tag-dark {
            background: rgba(59, 130, 246, 0.1);
            border: 1px solid rgba(59, 130, 246, 0.3);
            color: #93C5FD;
        }

        /* Gradient mesh background */
        .portfolio-bg {
            background:
                radial-gradient(ellipse 80% 50% at 20% 40%, rgba(59, 130, 246, 0.08) 0%, transparent 50%),
                radial-gradient(ellipse 60% 40% at 80% 60%, rgba(249, 115, 22, 0.05) 0%, transparent 50%),
                radial-gradient(ellipse 50% 30% at 50% 80%, rgba(16, 185, 129, 0.05) 0%, transparent 50%);
        }

        /* Grid pattern overlay */
        .grid-pattern {
            background-image:
                linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
            background-size: 50px 50px;
        }
</style>

        <main class="flex-grow">

            <!-- ================================================================== -->
            <!-- SECTION PORTFOLIO - STYLE IMMERSIF                                -->
            <!-- ================================================================== -->
            <section id="portfolio"
                class="pt-32 pb-24 lg:pt-44 lg:pb-32 bg-neutral-dark portfolio-bg grid-pattern relative overflow-hidden">

                <!-- Decorative elements -->
