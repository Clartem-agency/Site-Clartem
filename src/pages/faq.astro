<script is:inline>
        // --- 1. GESTION DU MENU DÉROULANT MOBILE ---
        const dropdownBtn = document.getElementById('dropdown-button');
        const dropdownMenu = document.getElementById('dropdown-menu');
        const dropdownLabel = document.getElementById('dropdown-label');
        const dropdownArrow = document.getElementById('dropdown-arrow');
        let isDropdownOpen = false;

        function toggleDropdown() {
            isDropdownOpen = !isDropdownOpen;
            if (isDropdownOpen) {
                dropdownMenu.classList.remove('hidden');
                dropdownArrow.classList.add('rotate-180');
            } else {
                dropdownMenu.classList.add('hidden');
                dropdownArrow.classList.remove('rotate-180');
            }
        }

        // Fermer le menu si on clique ailleurs
        document.addEventListener('click', function (event) {
            if (!dropdownBtn.contains(event.target) && !dropdownMenu.contains(event.target)) {
                if (isDropdownOpen) toggleDropdown();
            }
        });

        function selectOption(value, label) {
            // Mettre à jour le texte du bouton mobile
            if (dropdownLabel) dropdownLabel.innerText = label;

            // Fermer le menu
            toggleDropdown();

            // Changer le contenu
            switchTab(value);
        }

        // --- 2. FONCTION PRINCIPALE DE CHANGEMENT D'ONGLET (Desktop & Mobile) ---
        function switchTab(category) {

            // A. Masquer tous les contenus
            document.querySelectorAll('.tab-content').forEach(content => {
                content.classList.add('hidden');
                content.classList.remove('block');
            });

            // B. Afficher le contenu ciblé
            const targetContent = document.getElementById('content-' + category);
            if (targetContent) {
                targetContent.classList.remove('hidden');
                targetContent.classList.add('block');

                // Petit effet d'animation (reset)
                targetContent.classList.remove('animate-fade-in');
                void targetContent.offsetWidth; // force reflow
                targetContent.classList.add('animate-fade-in');
            }

            // C. Mettre à jour les boutons de la Sidebar (Desktop)
            document.querySelectorAll('.nav-btn').forEach(btn => {
                btn.classList.remove('active');
                // Remettre le style par défaut (gris)
                btn.classList.add('text-gray-400', 'border-transparent');
            });

            // Activer le bouton correspondant
            const activeBtn = document.getElementById('btn-' + category);
            if (activeBtn) {
                activeBtn.classList.add('active');
                activeBtn.classList.remove('text-gray-400', 'border-transparent');
            }

            // D. Synchroniser le label mobile (si on clique sur desktop)
            const labels = {
                'general': 'Général & Confiance',
                'tarifs': 'Tarifs & Investissement',
                'processus': 'Processus & Collaboration',
                'design': 'Contenu & Design',
                'technique': 'Technique & Gestion',
                'maintenance': 'Maintenance & Suivi'
            };
            if (dropdownLabel && labels[category]) {
                dropdownLabel.innerText = labels[category];
            }
        }
    </script>

