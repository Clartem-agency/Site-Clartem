---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contactez l'Agence - clartem.com"
  description="Discutons de votre projet de site web. Formulaire de contact direct pour coachs et thérapeutes."
  bodyClass="bg-neutral-dark text-white font-sans antialiased selection:bg-warm-orange selection:text-white dark-nav-page"
>

<style is:global>
        /* Style spécifique pour masquer l'input file natif */
        #file-upload-input {
            display: none;
        }

        /* Style des tags de fichiers uploadés */
        #file-list span {
            display: inline-flex;
            align-items: center;
            background-color: #EFF6FF;
            color: #1E3A8A;
            padding: 6px 12px;
            border-radius: 8px;
            font-size: 0.8rem;
            margin: 4px;
            font-weight: 600;
            border: 1px solid #BFDBFE;
        }

        /* Force la nav blanche sur fond sombre */
        .nav-dark-mode .nav-link {
            color: rgba(255, 255, 255, 0.9) !important;
        }

        .nav-dark-mode .nav-link:hover {
            color: #F97316 !important;
        }

        .nav-dark-mode #logo-white {
            opacity: 1 !important;
        }

        .nav-dark-mode #logo-color {
            opacity: 0 !important;
        }

        .nav-dark-mode #mobile-menu-button {
            color: white !important;
        }

        /* Au scroll, on repasse en mode normal (fond blanc, texte noir) géré par JS */
</style>

    <main class="relative min-h-screen pt-32 pb-20 overflow-hidden flex items-center">

        <!-- FOND : Grain & Lueurs (Cohérence Index) -->
        <div
            class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-20 mix-blend-soft-light pointer-events-none">
        </div>

        <!-- Lueur blanche (Bas Gauche) -->
        <div
            class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-white/10 rounded-full blur-[120px] pointer-events-none">
        </div>

        <!-- Lueur Bleue (Haut Droite) -->
        <div
            class="absolute top-0 right-0 w-[600px] h-[600px] bg-clarity-blue/10 rounded-full blur-[100px] pointer-events-none">
        </div>

        <div class="container mx-auto px-6 relative z-10">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-20 items-start">

                <!-- COLONNE GAUCHE : TEXTE & CONTEXTE -->
                <div class="lg:col-span-5 lg:sticky lg:top-32 pt-8">

                    <!-- Badge -->
                    <div
                        class="inline-flex items-center gap-2 px-3 py-1 mb-8 border border-white/10 rounded-full bg-white/5 backdrop-blur-md text-gray-300 text-xs font-bold tracking-widest uppercase shadow-sm">
                        <span class="relative flex h-2 w-2">
                            <span
                                class="animate-ping absolute inline-flex h-full w-full rounded-full bg-success-green opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2 w-2 bg-success-green"></span>
                        </span>
                        Ouvert aux nouveaux projets
                    </div>

                    <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
                        Parlons de votre <br>
                        <span
                            class="text-transparent bg-clip-text bg-gradient-to-r from-clarity-blue to-white">prochaine
                            étape.</span>
                    </h1>

                    <p class="text-lg text-gray-400 mb-10 leading-relaxed font-light">
                        Vous avez une vision, j'ai les outils pour la concrétiser. Remplissez le formulaire ci-contre
                        pour que je puisse préparer notre premier échange.
                    </p>

                    <!-- Info Email Direct (Subtil) -->
                    <div class="border-t border-white/10 pt-8">
                        <p class="text-sm text-gray-500 mb-2 uppercase tracking-wider font-bold">Contact Direct</p>
                        <a href="mailto:contact@clartem.com"
                            class="text-xl text-white hover:text-warm-orange transition-colors flex items-center gap-3 group">
                            contact@clartem.com
                            <svg xmlns="http://www.w3.org/2000/svg"
                                class="h-5 w-5 transform group-hover:translate-x-1 transition-transform" fill="none"
                                viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M17 8l4 4m0 0l-4 4m4-4H3" />
                            </svg>
                        </a>
                    </div>
                </div>




                <!-- COLONNE DROITE : LE FORMULAIRE (STYLE PREMIUM DARK) -->
                <div class="lg:col-span-7">
                    <!-- Cadre Premium : Fond sombre, flou, bordure fine -->
                    <div
                        class="bg-[#1E293B]/80 backdrop-blur-xl border border-white/10 rounded-3xl p-8 md:p-10 shadow-2xl relative overflow-hidden group">

                        <!-- Effet de lueur d'ambiance en haut à droite -->
                        <div
                            class="absolute -top-24 -right-24 w-64 h-64 bg-white/10 rounded-full blur-[80px] pointer-events-none group-hover:bg-white/20 transition-colors duration-500">
                        </div>

                        <!-- Ligne décorative (Gradient) -->
                        <div
                            class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-clarity-blue via-white to-white opacity-80">
                        </div>

                        <form id="contact-form" name="contact-form-agence" method="POST"
                            action="/merci-formulaire-contact/" netlify netlify-honeypot="bot-field"
                            enctype="multipart/form-data" class="space-y-6 relative z-10">

                            <p class="hidden"><label>Ne pas remplir : <input name="bot-field" /></label></p>
                            <input type="hidden" name="form-name" value="contact-form-agence" />
                            <input type="hidden" name="image-urls" id="cloudinary-urls">

                            <!-- IDENTITÉ -->
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div>
                                    <label for="first-name"
                                        class="block text-sm font-bold text-gray-300 mb-2">Prénom</label>
                                    <input type="text" name="first-name" id="first-name" placeholder="Votre prénom"
                                        required
                                        class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-gray-500 focus:bg-white/10 focus:border-warm-orange focus:ring-1 focus:ring-warm-orange outline-none transition-all">
                                </div>
                                <div>
                                    <label for="last-name"
                                        class="block text-sm font-bold text-gray-300 mb-2">Nom</label>
                                    <input type="text" name="last-name" id="last-name" placeholder="Votre nom" required
                                        class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-gray-500 focus:bg-white/10 focus:border-warm-orange focus:ring-1 focus:ring-warm-orange outline-none transition-all">
                                </div>
                            </div>

                            <!-- EMAIL (MODIFIÉ : PLUS GÉNÉRIQUE) -->
                            <div>
                                <label for="email" class="block text-sm font-bold text-gray-300 mb-2">Votre
                                    Email</label>
                                <input type="email" name="email" id="email" placeholder="jean.dupont@email.com" required
                                    class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-gray-500 focus:bg-white/10 focus:border-warm-orange focus:ring-1 focus:ring-warm-orange outline-none transition-all">
                            </div>

                            <!-- SUJET -->
                            <div>
                                <label for="subject" class="block text-sm font-bold text-gray-300 mb-2">Quel est l'objet
                                    de votre demande ?</label>
                                <div class="relative">
                                    <select id="subject" name="subject" required
                                        class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white focus:bg-white/10 focus:border-warm-orange focus:ring-1 focus:ring-warm-orange outline-none transition-all appearance-none cursor-pointer">
                                        <!-- Option par défaut grisée -->
                                        <option value="" disabled selected class="bg-neutral-dark text-gray-500">
                                            Sélectionnez une option...</option>
                                        <!-- Options avec fond sombre pour lisibilité -->
                                        <option value="ready" class="bg-neutral-dark">🚀 Je suis prêt à lancer mon Site
                                            Clarté</option>
                                        <option value="hesitation" class="bg-neutral-dark">🤔 J'hésite entre deux offres
                                        </option>
                                        <option value="partner" class="bg-neutral-dark">🤝 Proposition de partenariat /
                                            Collab</option>
                                        <option value="job" class="bg-neutral-dark">👋 Candidature spontanée (Rejoindre
                                            Clartem)</option>
                                        <option value="other" class="bg-neutral-dark">✉️ Autre demande / Simple bonjour
                                        </option>
                                    </select>
                                    <!-- Flèche custom blanche -->
                                    <div
                                        class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-gray-400">
                                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M19 9l-7 7-7-7"></path>
                                        </svg>
                                    </div>
                                </div>
                            </div>

                            <!-- MESSAGE -->
                            <div>
                                <label for="message" class="block text-sm font-bold text-gray-300 mb-2">Votre
                                    Message</label>
                                <textarea id="message" name="message" rows="5"
                                    placeholder="Parlez-moi de votre activité, de vos objectifs actuels et de ce qui vous bloque..."
                                    required
                                    class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-gray-500 focus:bg-white/10 focus:border-warm-orange focus:ring-1 focus:ring-warm-orange outline-none transition-all resize-y"></textarea>
                            </div>

                            <!-- UPLOAD FICHIER (Style Dark) -->
                            <div>
                                <label class="block text-sm font-bold text-gray-300 mb-2">Pièce jointe
                                    (Optionnel)</label>
                                <label for="file-upload-input"
                                    class="group flex flex-col items-center justify-center w-full h-24 border-2 border-white/10 border-dashed rounded-xl cursor-pointer bg-white/5 hover:bg-white/10 hover:border-warm-orange/50 transition-all duration-300">
                                    <div class="flex flex-col items-center justify-center pt-5 pb-6">
                                        <div
                                            class="flex items-center gap-2 text-gray-400 group-hover:text-white transition-colors">
                                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M7 16a4 4 0 01-4-4V7a4 4 0 014-4h.586a1 1 0 01.707.293l2.414 2.414a1 1 0 00.707.293h3.172a1 1 0 00.707-.293l2.414-2.414A1 1 0 0116.414 3H17a4 4 0 014 4v5a4 4 0 01-4 4H7z">
                                                </path>
                                            </svg>
                                            <span class="text-sm font-medium">Cliquez pour ajouter une image (jpg, png,
                                                webp...)</span>
                                        </div>
                                    </div>
                                    <input id="file-upload-input" type="file" multiple accept="image/*,application/pdf">
                                </label>
                                <div id="file-list" class="mt-3 flex flex-wrap gap-2 text-gray-300"></div>
                            </div>

                            <!-- CONSENTEMENT -->
                            <div class="flex items-start pt-2">
                                <div class="flex items-center h-5">
                                    <input id="consent-contact" name="consent-contact" type="checkbox" required
                                        class="w-4 h-4 text-warm-orange border-gray-600 rounded bg-white/10 focus:ring-warm-orange cursor-pointer">
                                </div>
                                <div class="ml-3 text-sm">
                                    <label for="consent-contact" class="text-gray-400">
                                        En soumettant ce formulaire, j'accepte que mes informations soient utilisées
                                        exclusivement dans le cadre de ma demande et de la relation commerciale éthique
                                        qui peut en découler. J'ai lu et j'accepte la <a
                                            href="/politique-de-confidentialite/" target="_blank"
                                            class="text-white font-semibold hover:underline decoration-warm-orange">Politique
                                            de confidentialité</a>.
                                    </label>
                                </div>
                            </div>

                            <!-- BOUTON SUBMIT -->
                            <div class="pt-4">
                                <button type="submit" id="submit-button"
                                    class="w-full btn btn-orange text-lg font-bold py-4 shadow-lg shadow-orange-500/20 hover:shadow-orange-500/40 relative overflow-hidden group">
                                    <span class="relative z-10">Envoyer mon message</span>
                                    <!-- Petit effet brillance au survol -->
                                    <div
                                        class="absolute inset-0 h-full w-full bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:animate-[shimmer_1.5s_infinite]">
                                    </div>
                                </button>


                                <!-- AJOUT : Phrase de réassurance -->
                                <div class="mt-4 flex items-center justify-center gap-2 text-sm text-gray-400">
                                    <span class="relative flex h-2 w-2">
                                        <span
                                            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-success-green opacity-75"></span>
                                        <span class="relative inline-flex rounded-full h-2 w-2 bg-success-green"></span>
                                    </span>
                                    <span class="font-medium">Réponse humaine sous 48h.</span>
                                </div>
                                <!-- FIN AJOUT -->


                                <p id="form-status" class="mt-4 text-sm font-medium text-center text-gray-300"></p>
                            </div>

                        </form>
                    </div>
                </div>




            </div>
        </div>
    </main>


<script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
            // 2. LOGIQUE CLOUDINARY (Upload Fichiers)
            const contactForm = document.getElementById('contact-form');
            const fileInput = document.getElementById('file-upload-input');
            const fileListContainer = document.getElementById('file-list');
            const formStatus = document.getElementById('form-status');
            const submitButton = document.getElementById('submit-button');
            const cloudinaryUrlsInput = document.getElementById('cloudinary-urls');

            // --- VOS IDENTIFIANTS (Inchangés) ---
            const CLOUDINARY_CLOUD_NAME = "dbihs2rzm";
            const CLOUDINARY_UPLOAD_PRESET = "clartem-contact-upload";
            const CLOUDINARY_URL = `https://api.cloudinary.com/v1_1/${CLOUDINARY_CLOUD_NAME}/image/upload`;

            fileInput.addEventListener('change', function () {
                fileListContainer.innerHTML = '';
                if (this.files.length > 0) {
                    for (const file of this.files) {
                        const fileTag = document.createElement('span');
                        fileTag.textContent = file.name;
                        fileListContainer.appendChild(fileTag);
                    }
                }
            });

            contactForm.addEventListener('submit', async function (event) {
                event.preventDefault();
                const files = fileInput.files;

                if (files.length === 0) {
                    this.submit();
                    return;
                }

                submitButton.disabled = true;
                const originalBtnText = submitButton.querySelector('span').textContent;
                submitButton.querySelector('span').textContent = 'Téléversement en cours...';
                formStatus.textContent = `Envoi de 1/${files.length} fichier(s)...`;
                formStatus.className = 'mt-4 text-sm font-medium text-center text-clarity-blue';

                const uploadedUrls = [];

                try {
                    for (let i = 0; i < files.length; i++) {
                        const file = files[i];
                        formStatus.textContent = `Envoi de ${i + 1}/${files.length} fichier(s)...`;

                        const formData = new FormData();
                        formData.append('file', file);
                        formData.append('upload_preset', CLOUDINARY_UPLOAD_PRESET);

                        const response = await fetch(CLOUDINARY_URL, {
                            method: 'POST',
                            body: formData,
                        });

                        if (!response.ok) throw new Error('Erreur upload');
                        const data = await response.json();
                        uploadedUrls.push(data.secure_url);
                    }

                    const finalUrls = uploadedUrls.join(', ');

                    // 1. On remplit le champ caché pour le dashboard Netlify (comme avant)
                    cloudinaryUrlsInput.value = finalUrls;

                    // --- MODIFICATION DÉBUT : On injecte aussi le lien dans le message principal ---
                    const messageArea = document.getElementById('message');
                    if (messageArea) {
                        // On ajoute deux sauts de ligne et le lien
                        messageArea.value += "\n\n--------------------------------\n📎 PIÈCES JOINTES :\n" + finalUrls;
                    }
                    // --- MODIFICATION FIN ---

                    formStatus.textContent = 'Envoi du message...';
                    this.submit();

                } catch (error) {
                    console.error(error);
                    formStatus.textContent = "Erreur lors de l'envoi des fichiers.";
                    formStatus.className = 'mt-4 text-sm font-medium text-center text-destructive';
                    submitButton.disabled = false;
                    submitButton.querySelector('span').textContent = originalBtnText;
                }
            });
    });
</script>
</Layout>
